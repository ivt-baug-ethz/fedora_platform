{
  "scenario": "vienna",
  "scenario_path": "scenarios/pilot_vienna/sumo",
  "communication": {
    "host": "127.0.0.1",
    "ports": {
      "orchestrator": 51000,
      "environment": 51001,
      "recorder": 51003,
      "logic_module": 51002
    },
    "socket_timeout": 2.0
  },
  "setup": {
    "measurements": {
      "sumo": {
        "lane_measurements": {
          "pressure_lanes": "phase_inc_lanes.json"
        },
        "measurement_details": {
          "sensor_distance": 100.0
        },
        "road_measurements": {},
        "sensor_measurements": {},
        "vehicle_measurements": {}
      }
    },
    "startup_pause_seconds": 0.2,
    "random_seed": 42,
    "traffic_lights": [
      "J25",
      "J26",
      "J27",
      "J28",
      "J29",
      "J30",
      "J31",
      "J32",
      "J33"
    ],
    "controller_response_timeout_seconds": 0.05
  },
  "environment": {
    "type": "sumo",
    "demand": {
      "traci_spawning_active": true,
      "route_probabilities_file": "route_probabilities.json",
      "flow_per_entrance_per_hour": 50.0,
      "spawn_horizon": 30000,
      "max_steps": 5000,
      "step_delay_seconds": 0.0,
      "vot_spawn_probabilities": {
        "0": 1.0
      }
    },
    "visualization": {
      "vehicle_colors": {
        "regular": [110, 110, 110, 255]
      }
    },
    "settings": {
      "binary": "sumo-gui",
      "binary_headless": "sumo",
      "config_file": "config.sumocfg",
      "label": "vienna_fixed_cycle"
    }
  },
  "recorder": {
    "logs_dir": "logs/vienna_fixed_cycle",
    "log_type": "txt",
    "topics": [],
    "vehicle_log_enabled": true,
    "state_polling": {
      "interval_steps": 1,
      "environment_state": {
        "step": true,
        "time": true,
        "vehicle_ids": true,
        "vehicle_lanes": true,
        "vehicle_lane_positions": true,
        "vehicle_upp": true,
        "pending_commands": true,
        "vehicle_speeds": false,
        "vehicle_waiting_times": false
      },
      "logic_module_state": {
        "step": true,
        "controller_type": true,
        "light_states": true
      }
    }
  },
  "logic_modules": [
    {
      "type": "controller_fixed_cycle",
      "fixed_cycle": {
        "transition_duration": 3,
        "phase_durations": [29, 21, 29, 21],
        "default_time_delay": 0,
        "time_delays": {
          "J25": 0,
          "J26": 25,
          "J27": 0,
          "J28": 25,
          "J29": 0,
          "J30": 0,
          "J31": 25,
          "J32": 25,
          "J33": 0
        }
      }
    }
  ]
}
